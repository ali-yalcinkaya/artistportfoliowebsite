---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title,
  description = 'Tezhip ve minyatür sanatçısı B. Figen Yalçınkaya’nın eserleri, biyografisi ve iletişim bilgileri.',
} = Astro.props;

const fullTitle = title ? `${title} — ${site.name}` : `${site.name} · ${site.role}`;
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="generator" content={Astro.generator} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="flex min-h-screen flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <!-- Netlify Identity: davet / şifre belirleme akışı ve /admin yönlendirmesi -->
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <script is:inline>
      (function () {
        // Davet, şifre sıfırlama veya e-posta onay bağlantısıyla gelindi mi?
        var hasAuthToken = /\b(invite_token|recovery_token|confirmation_token|email_change_token)=/.test(
          window.location.hash || ''
        );

        function setup() {
          var ni = window.netlifyIdentity;
          if (!ni) return;

          ni.on('init', function (user) {
            if (!user) {
              ni.on('login', function () {
                document.location.href = '/admin/';
              });
            }
            // Davet/şifre penceresini otomatik aç
            if (hasAuthToken) ni.open();
          });

          // 'init' zaten tetiklenmiş olabilir; token varsa pencereyi garantiye al
          if (hasAuthToken) {
            try { ni.open(); } catch (e) {}
          }
        }

        if (window.netlifyIdentity) {
          setup();
        } else {
          window.addEventListener('load', setup);
        }
      })();
    </script>
  </body>
</html>

---
import { site, nav } from '../data/site';
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header class="sticky top-0 z-50 border-b border-line/70 bg-parchment/85 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-4">
    <a href="/" class="group flex flex-col leading-none">
      <span class="font-[family-name:var(--font-display)] text-xl tracking-wide text-hunter-deep sm:text-2xl">
        {site.name}
      </span>
      <span class="eyebrow mt-1 text-[0.6rem] sm:text-[0.66rem]">{site.role}</span>
    </a>

    <!-- Masaüstü menü -->
    <nav class="hidden items-center gap-8 md:flex" aria-label="Ana menü">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'link-underline font-[family-name:var(--font-serif)] text-[0.95rem] tracking-wide transition-colors',
            isActive(item.href) ? 'text-gold' : 'text-ink-soft hover:text-hunter',
          ]}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Mobil menü butonu -->
    <button
      id="menu-toggle"
      class="flex h-10 w-10 items-center justify-center text-hunter md:hidden"
      aria-label="Menüyü aç/kapat"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
        <line x1="4" y1="7" x2="20" y2="7"></line>
        <line x1="4" y1="12" x2="20" y2="12"></line>
        <line x1="4" y1="17" x2="20" y2="17"></line>
      </svg>
    </button>
  </div>

  <!-- Mobil menü -->
  <nav
    id="mobile-menu"
    class="hidden border-t border-line/70 bg-parchment px-6 py-4 md:hidden"
    aria-label="Mobil menü"
  >
    <ul class="flex flex-col gap-1">
      {nav.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              'block py-2 text-lg tracking-wide',
              isActive(item.href) ? 'text-gold' : 'text-ink-soft',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, bio, exhibitions, books } from '../data/site';
import about from '../data/about.json';

// Sanatçı portre fotoğrafı /admin → "Ayarlar" panelinden yüklenir.
// Henüz yüklenmediyse zarif bir eser görseli yedek olarak gösterilir.
const hasPhoto = Boolean(about.photo && about.photo.trim());
const portraitSrc = hasPhoto ? about.photo : '/images/artworks/eser-17.jpeg';
const portraitAlt = hasPhoto ? site.name : 'Kâbe — minyatür çalışması';
const portraitCaption = hasPhoto ? site.role : 'Kâbe · Minyatür';
---

<BaseLayout title="Hakkımda">
  <section class="border-b border-line/70 bg-parchment-deep">
    <div class="mx-auto max-w-6xl px-6 py-16 text-center">
      <p class="eyebrow">Sanatçı</p>
      <h1 class="mt-3 text-5xl">Hakkımda</h1>
      <div class="ornament my-6"></div>
      <p class="mx-auto max-w-xl text-ink-soft">Figen Yalçınkaya’nın Sanat Yolculuğu</p>
    </div>
  </section>

  <section class="mx-auto grid max-w-6xl gap-12 px-6 py-16 md:grid-cols-[1.3fr_1fr]">
    <!-- Biyografi -->
    <div class="space-y-6">
      {bio.map((p) => (
        <p class="text-[1.05rem] leading-[1.85] text-ink">{p}</p>
      ))}
    </div>

    <!-- Sanatçı portresi -->
    <aside class="md:pt-2">
      <div class="relative">
        <div class="absolute -inset-2.5 rounded-sm border border-gold/30"></div>
        <img
          src={portraitSrc}
          alt={portraitAlt}
          class="relative w-full rounded-sm object-cover shadow-lg"
          loading="lazy"
        />
      </div>
      <p class="mt-3 text-center text-xs uppercase tracking-[0.18em] text-gold">
        {portraitCaption}
      </p>
    </aside>
  </section>

  <!-- Sergiler -->
  <section class="border-t border-line/70 bg-parchment-deep/60">
    <div class="mx-auto max-w-4xl px-6 py-16">
      <div class="mb-10 text-center">
        <p class="eyebrow">1994 – 2025</p>
        <h2 class="mt-2 text-4xl">Sergilerden Seçkiler</h2>
      </div>
      <ol class="space-y-5">
        {exhibitions.map((ex) => (
          <li class="grid grid-cols-[3.5rem_1fr] gap-4 border-b border-line/60 pb-5">
            <span class="font-[family-name:var(--font-display)] text-xl text-gold">{ex.year}</span>
            <span class="text-ink-soft leading-relaxed">{ex.text}</span>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Kitaplar -->
  <section class="mx-auto max-w-4xl px-6 py-16">
    <div class="mb-10 text-center">
      <p class="eyebrow">Yayınlar</p>
      <h2 class="mt-2 text-4xl">Eserlerin Yer Aldığı Kitaplar</h2>
    </div>
    <ul class="grid gap-4 sm:grid-cols-2">
      {books.map((b) => (
        <li class="flex gap-4 rounded-sm border border-line bg-white/60 px-5 py-4">
          <span class="font-[family-name:var(--font-display)] text-lg text-gold">{b.year}</span>
          <span class="text-ink-soft leading-snug">{b.title}</span>
        </li>
      ))}
    </ul>
  </section>

  <!-- İletişim çağrısı -->
  <section class="mx-auto max-w-3xl px-6 pb-8 text-center">
    <div class="ornament mb-6"></div>
    <p class="text-ink-soft">Eserler ve iş birlikleri hakkında bilgi almak için</p>
    <a
      href="/iletisim"
      class="mt-5 inline-block rounded-sm bg-hunter px-8 py-3 text-sm uppercase tracking-[0.16em] text-parchment transition-colors hover:bg-hunter-deep"
    >
      İletişime Geç
    </a>
  </section>
</BaseLayout>
